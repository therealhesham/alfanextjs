  updated_at         DateTime @default(now()) @db.Timestamp(0)
  users              users?   @relation(fields: [created_by_user_id], references: [id], map: "fk_complaints_created_by")

  @@index([created_by_user_id], map: "idx_complaints_created_by")
}

